# ---- Server ----
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---- Database (Docker maps host 5435 -> container 5432) ----
DATABASE_URL=postgresql://nba:nba_password@localhost:5435/nangalkot_bazar

# ---- Auth ----
JWT_SECRET=change_me_to_a_long_random_hex_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ---- Auth cookie ----
COOKIE_NAME=nba_token
# false over http://localhost in dev; true in production (https)
COOKIE_SECURE=false
# localhost:3000 and :4000 are same-site -> lax works in dev
COOKIE_SAMESITE=lax
COOKIE_MAX_AGE_MS=604800000

# ---- Cloudinary (optional — app degrades to local-disk uploads if unset) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=nangalkot-bazar

# ---- Seed admin (documented in README; change for production) ----
SEED_ADMIN_NAME=প্রশাসক
SEED_ADMIN_EMAIL=admin@nangalkotbazar.test
SEED_ADMIN_PASSWORD=Admin@12345
