# Browser-facing API base (client-side fetch). No trailing slash; the api client appends /api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Server-side base for Server Components / Route Handlers (kept separate so prod can use an internal URL).
API_INTERNAL_BASE_URL=http://localhost:4000

# Canonical site URL (used in metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Default language (bn = Bangla, en = English). Bangla is the default.
NEXT_PUBLIC_DEFAULT_LOCALE=bn
